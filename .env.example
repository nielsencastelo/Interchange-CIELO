# ============================================================
# Interchange AI — Variáveis de Ambiente
# ============================================================
# Copie: cp .env.example .env
# Preencha os valores conforme seu ambiente
# ============================================================

APP_NAME=interchange-ai

# --- Banco de Dados ---
# SQLite (padrão — zero config):
DATABASE_URL=sqlite+pysqlite:///./interchange_ai.db
# PostgreSQL (requer Docker):
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/interchange_ai

SAMPLE_CSV_PATH=data/sample_interchange_rules.csv

# --- Qual provedor LLM usar ---
# anthropic | openai | gemini | ollama
LLM_PROVIDER=anthropic

# Ativar normalização LLM (false = apenas regex, sem custo de API)
ENABLE_LLM_NORMALIZATION=false

# --- Anthropic Claude (https://console.anthropic.com/) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OpenAI GPT (https://platform.openai.com/) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# --- Google Gemini (https://aistudio.google.com/) ---
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Ollama (local, zero custo — https://ollama.ai) ---
# Instale: curl -fsSL https://ollama.ai/install.sh | sh
# Baixe:   ollama pull llama3.1
# Rode:    ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Logging ---
LOG_LEVEL=INFO
